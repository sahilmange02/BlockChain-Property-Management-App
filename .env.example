# ============================================================
# BLOCKCHAIN SETTINGS
# ============================================================

# BLOCKCHAIN EXPLAINED: This is the private key of the wallet that will
# DEPLOY the smart contract. Think of it as the "admin password" for the
# blockchain. For LOCAL development, Hardhat gives you free test wallets —
# you can copy one from the terminal when you run "npx hardhat node".
# NEVER use your real wallet's private key here. NEVER commit this file to git.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# ^^^ This is Hardhat's default test Account #0 — safe to use for LOCAL dev only

# For Sepolia testnet: use your own MetaMask private key.
# Get free Sepolia ETH at: https://sepoliafaucet.com
SEPOLIA_PRIVATE_KEY=your_metamask_private_key_for_sepolia_only

# BLOCKCHAIN EXPLAINED: The RPC URL is the "address" of the blockchain node.
# For LOCAL dev, Hardhat runs the node at this address automatically.
# You do NOT need Alchemy or Infura for local development.
LOCAL_RPC_URL=http://127.0.0.1:8545

# For Sepolia testnet, use a free public RPC endpoint (no signup needed):
SEPOLIA_RPC_URL=https://rpc.sepolia.org
# Alternative free Sepolia RPCs (use any):
# https://ethereum-sepolia.blockpi.network/v1/rpc/public
# https://sepolia.drpc.org

# Etherscan is only needed to VERIFY your contract publicly (optional for dev)
# Get a free key at: https://etherscan.io/register
ETHERSCAN_API_KEY=your_etherscan_key_optional

# ============================================================
# IPFS SETTINGS (Pinata — free online IPFS storage)
# ============================================================

# Pinata IPFS (free online IPFS storage — no local node needed)
# Sign up free at: https://app.pinata.cloud/register
# Then: API Keys → New Key → copy API Key and Secret
PINATA_API_KEY=your_key_here
PINATA_SECRET_API_KEY=your_secret_here
IPFS_GATEWAY_URL=https://gateway.pinata.cloud

# ============================================================
# BACKEND SETTINGS
# ============================================================

# MongoDB connection string. For local dev, Docker runs MongoDB for you.
# When using docker-compose, the hostname is "mongodb" (the service name).
MONGODB_URI=mongodb://localhost:27017/land_registry

# JWT EXPLAINED: When a user logs in, we give them a "token" — like a
# wristband at an event. Every request they make, they show the wristband.
# JWT_SECRET is the secret code used to CREATE and VERIFY those wristbands.
# Make this long and random. Generate one at: https://randomkeygen.com
JWT_SECRET=replace_this_with_a_very_long_random_string_at_least_64_characters
JWT_EXPIRES_IN=7d

PORT=5000
NODE_ENV=development

# ============================================================
# CONTRACT ADDRESSES (fill these AFTER running deploy scripts)
# ============================================================

# BLOCKCHAIN EXPLAINED: When you deploy a smart contract, it gets an
# "address" on the blockchain — like a street address for your code.
# After running "npm run deploy:local", copy the address printed in the
# terminal and paste it here.
CONTRACT_ADDRESS_LOCAL=    # Fill after: npm run deploy:local
CONTRACT_ADDRESS_SEPOLIA=  # Fill after: npm run deploy:sepolia

# ============================================================
# FRONTEND SETTINGS
# ============================================================

# VITE_ prefix = these variables are visible in the browser (public)
# Never put secret keys with the VITE_ prefix!
VITE_API_URL=http://localhost:5000/api
VITE_CONTRACT_ADDRESS=     # Same as CONTRACT_ADDRESS_LOCAL during dev
VITE_CHAIN_ID=31337        # 31337 = Hardhat local network ID
                           # 11155111 = Sepolia testnet ID

