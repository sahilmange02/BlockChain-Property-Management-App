# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/land_registry

# JWT
JWT_SECRET=mylandreg2025harshaldamasecretkey9876543210abcdef

# KYC hashing salt (for Aadhaar/PAN hashing)
KYC_HASH_SALT=mssgkm2025kycsalt$harshal

# Email Configuration (Optional - for email verification)
# For Gmail: use "gmail" and enable "Less secure app access" or use App Password
# For other services, change EMAIL_SERVICE to the appropriate service name
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-or-password

# Blockchain
LOCAL_RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS_LOCAL= 

# For Sepolia
# SEPOLIA_RPC_URL=https://rpc.sepolia.org
# CONTRACT_ADDRESS_SEPOLIA=

# Pinata IPFS (free online IPFS storage — no local node needed)
# Sign up free at: https://app.pinata.cloud/register
# Then: API Keys → New Key → copy API Key and Secret


# Frontend (for CORS)
FRONTEND_URL=http://localhost:3000
